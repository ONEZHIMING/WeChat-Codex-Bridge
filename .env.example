# ===== Runtime =====
INSTANCE_ID=wx1
ENABLE_PROGRESS_STREAM=0
ENABLE_TYPING=1
ENABLE_PERSONA=1

# ===== Codex =====
CODEX_TIMEOUT_MS=90000
# CODEX_MODEL=
# CODEX_PROFILE=
# CODEX_SANDBOX=

# ===== Storage Files =====
PERSONA_FILE=soule.md
MEMORY_DB_FILE=.wechat-memory.db

# ===== Memory =====
MEMORY_ENABLED=1
MEMORY_TOPK=5
MEMORY_MAX_CHARS=400
MEMORY_MIN_CONFIDENCE=0.72
MEMORY_TTL_DAYS=180
MEMORY_EXPORT_DIR=./exports

# ===== Voice Transport (no TTS in this edition) =====
WEIXIN_VOICE_CODEC=silk
WEIXIN_SILK_SAMPLE_RATE=24000
WEIXIN_VOICE_UPLOAD_MEDIA_TYPE=3
WEIXIN_VOICE_DISABLE=0
